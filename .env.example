# Shared workspace environment template
# Copy this file to both .env.dev and .env.prd in the repository root.
# frontend/admin read this file directly.
# functions also use this file as the source of truth.

# ---- Shared app settings ----
VITE_APP_NAME=Desktop App Template
VITE_APP_DESCRIPTION=Desktop application starter with Tauri, Firebase Functions, TiDB, and admin console.
VITE_APP_WEBSITE_URL=https://example.com
VITE_ADMIN_CONSOLE_URL=https://example.com/admin

# ---- Firebase project settings ----
FIREBASE_PROJECT_ID=template-firebase-project
FIREBASE_FUNCTIONS_REGION=asia-northeast1
VITE_FUNCTIONS_REGION=asia-northeast1
VITE_FUNCTIONS_PROJECT_ID=template-firebase-project
VITE_FUNCTIONS_URL=https://asia-northeast1-template-firebase-project.cloudfunctions.net
# Usually optional for desktop builds. Leave blank to auto-build from region + project ID.
VITE_FUNCTIONS_PUBLIC_URL=

# ---- Google Cloud service account (optional) ----
# 1. If you already have a JSON file, set GOOGLE_APPLICATION_CREDENTIALS to its path.
#    Relative paths are resolved from the repository root.
GOOGLE_APPLICATION_CREDENTIALS=
# 2. Or put the JSON itself in one line.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# 3. Or put a base64-encoded JSON string.
GOOGLE_APPLICATION_CREDENTIALS_BASE64=

# ---- Firebase Web SDK ----
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=template-firebase-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=template-firebase-project
VITE_FIREBASE_STORAGE_BUCKET=template-firebase-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://template-firebase-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- Desktop/web app options ----
# Optional override for the static website Firebase config generator.
# Leave blank to use "<env-profile>-firebase-store".
WEBSITE_FIRESTORE_DATABASE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
VITE_GOOGLE_CLIENT_ID=your_web_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID_DESKTOP=your_desktop_google_client_id.apps.googleusercontent.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_ENABLE_BILLING=false
VITE_ENABLE_WATCHED_WALLETS=false
VITE_ENABLE_TRANSACTIONS=false
VITE_ENABLE_CONTACTS=false
VITE_ENABLE_LABELS=false

# ---- Firebase Functions / Realtime Database ----
FIREBASE_DATABASE_URL=https://template-firebase-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- TiDB ----
# .env.dev では dev / dev_admin、.env.prd では prd / prd_admin を設定
TIDB_HOST=your_tidb_host.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your_tidb_user
TIDB_PASS=your_tidb_password
TIDB_DB=dev
TIDB_DB_ADMIN=dev_admin

# ---- Email ----
RESEND_API_KEY=re_your_api_key
RESEND_FROM=noreply@yourdomain.com
RESEND_FROM_NAME=Your App Name

# ---- Stripe ----
# .env.dev ではテスト用、.env.prd では本番用の値を設定
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Social login ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_DESKTOP=your_desktop_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_DESKTOP=your_desktop_google_client_secret
LINE_CHANNEL_ID=your_line_channel_id
APPLE_CLIENT_ID=com.yourcompany.yourapp

# ---- Optional API flags ----
ENABLE_BILLING_API=false
ENABLE_WALLET_API=false
ENABLE_TRANSACTION_API=false
ENABLE_CONTACT_API=false
ENABLE_LABEL_API=false
