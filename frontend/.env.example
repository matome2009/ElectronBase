# Vite 環境変数テンプレート
# このファイルをコピーして .env.development / .env.production を作成してください
# Firebase Console → プロジェクト設定 → マイアプリ から値を取得

VITE_ENV=development

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.asia-southeast1.firebasedatabase.app

# DB ルートパス（dev / prd）
VITE_DB_ROOT=dev

# Firebase Functions の URL
VITE_FUNCTIONS_URL=https://asia-northeast1-your_project_id.cloudfunctions.net

# Stripe 公開可能キー（dev: pk_test_... / prd: pk_live_...）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
