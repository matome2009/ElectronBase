{
  "hosting": [
    {
      "target": "website",
      "public": "website",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    },
    {
      "target": "dev",
      "public": "frontend/dist/renderer",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" },
            { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/api/getNonce", "function": "getNonce", "region": "asia-northeast1" },
        { "source": "/api/verifyWalletConnect", "function": "verifyWalletConnect", "region": "asia-northeast1" },
        { "source": "/api/verifyGoogleToken", "function": "verifyGoogleToken", "region": "asia-northeast1" },
        { "source": "/api/verifyLineToken", "function": "verifyLineToken", "region": "asia-northeast1" },
        { "source": "/api/startAsGuest", "function": "startAsGuest", "region": "asia-northeast1" },
        { "source": "/api/linkLogin", "function": "linkLogin", "region": "asia-northeast1" },
        { "source": "/api/sendKycNotifications", "function": "sendKycNotificationsDev", "region": "asia-northeast1" },
        { "source": "/api/submitKyc", "function": "submitKycDev", "region": "asia-northeast1" },
        { "source": "/api/resendKycNotification", "function": "resendKycNotificationDev", "region": "asia-northeast1" },
        { "source": "/api/createCheckoutSession", "function": "createCheckoutSessionDev", "region": "asia-northeast1" },
        { "source": "/api/verifyCheckoutSession", "function": "verifyCheckoutSessionDev", "region": "asia-northeast1" },
        { "source": "/api/cancelSubscription", "function": "cancelSubscriptionDev", "region": "asia-northeast1" },
        { "source": "/api/reactivateSubscription", "function": "reactivateSubscriptionDev", "region": "asia-northeast1" },
        { "source": "/api/reportUsage", "function": "reportUsageDev", "region": "asia-northeast1" },
        { "source": "/api/stripeWebhook", "function": "stripeWebhookDev", "region": "asia-northeast1" },
        { "source": "/api/sendTestEmail", "function": "sendTestEmailDev", "region": "asia-northeast1" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "prd",
      "public": "frontend/dist/renderer",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" },
            { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/api/getNonce", "function": "getNonce", "region": "asia-northeast1" },
        { "source": "/api/verifyWalletConnect", "function": "verifyWalletConnect", "region": "asia-northeast1" },
        { "source": "/api/verifyGoogleToken", "function": "verifyGoogleToken", "region": "asia-northeast1" },
        { "source": "/api/verifyLineToken", "function": "verifyLineToken", "region": "asia-northeast1" },
        { "source": "/api/startAsGuest", "function": "startAsGuest", "region": "asia-northeast1" },
        { "source": "/api/linkLogin", "function": "linkLogin", "region": "asia-northeast1" },
        { "source": "/api/sendKycNotifications", "function": "sendKycNotificationsPrd", "region": "asia-northeast1" },
        { "source": "/api/submitKyc", "function": "submitKycPrd", "region": "asia-northeast1" },
        { "source": "/api/resendKycNotification", "function": "resendKycNotificationPrd", "region": "asia-northeast1" },
        { "source": "/api/createCheckoutSession", "function": "createCheckoutSessionPrd", "region": "asia-northeast1" },
        { "source": "/api/verifyCheckoutSession", "function": "verifyCheckoutSessionPrd", "region": "asia-northeast1" },
        { "source": "/api/cancelSubscription", "function": "cancelSubscriptionPrd", "region": "asia-northeast1" },
        { "source": "/api/reactivateSubscription", "function": "reactivateSubscriptionPrd", "region": "asia-northeast1" },
        { "source": "/api/reportUsage", "function": "reportUsagePrd", "region": "asia-northeast1" },
        { "source": "/api/stripeWebhook", "function": "stripeWebhookPrd", "region": "asia-northeast1" },
        { "source": "/api/sendTestEmail", "function": "sendTestEmailPrd", "region": "asia-northeast1" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "admin-dev",
      "public": "admin/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "admin-prd",
      "public": "admin/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    }
  ],
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
