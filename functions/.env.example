# Firebase Functions 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp functions/.env.example functions/.env

# ---- Firebase / Realtime Database ----
# Firebase Console → Realtime Database から取得
# 例: https://your_project_id-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_DATABASE_URL=https://template-firebase-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- TiDB 接続設定 ----
# TiDB Cloud Console → クラスター → 接続 から取得

TIDB_HOST_DEV=your_tidb_host.tidbcloud.com
TIDB_PORT_DEV=4000
TIDB_USER_DEV=your_tidb_user
TIDB_PASS_DEV=your_tidb_password
TIDB_DB_DEV=dev
TIDB_DB_ADMIN_DEV=dev_admin

TIDB_HOST_PRD=your_tidb_host.tidbcloud.com
TIDB_PORT_PRD=4000
TIDB_USER_PRD=your_tidb_user
TIDB_PASS_PRD=your_tidb_password
TIDB_DB_PRD=prd
TIDB_DB_ADMIN_PRD=prd_admin

# ---- Resend メール設定 ----
# Resend Dashboard (resend.com) → API Keys から取得
RESEND_API_KEY=re_your_api_key
# 送信元アドレス（Resend で認証済みドメインのアドレスを使用）
RESEND_FROM=noreply@yourdomain.com
# 送信者表示名（省略可）
RESEND_FROM_NAME=Your App Name

# ---- Stripe 従量課金 ----
# Stripe Dashboard → API キー から取得

# DEV（テスト環境: sk_test_...）
STRIPE_SECRET_KEY_DEV=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID_DEV=price_your_dev_price_id
STRIPE_WEBHOOK_SECRET_DEV=whsec_your_dev_webhook_secret
STRIPE_METER_EVENT_NAME_DEV=your_meter_event_name

# PRD（本番環境: sk_live_...）
STRIPE_SECRET_KEY_PRD=sk_live_your_stripe_secret_key
STRIPE_PRICE_ID_PRD=price_your_prd_price_id
STRIPE_WEBHOOK_SECRET_PRD=whsec_your_prd_webhook_secret
STRIPE_METER_EVENT_NAME_PRD=your_meter_event_name

# ---- ソーシャルログイン設定 ----
# Google: Google Cloud Console → OAuth 2.0 クライアント ID から取得
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID_DESKTOP=your_desktop_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET_DESKTOP=your_desktop_google_client_secret
# LINE: LINE Developers Console → チャネル基本設定 → チャネルID
LINE_CHANNEL_ID=your_line_channel_id
# Apple: Apple Developer Console → Certificates, Identifiers → Services IDs
APPLE_CLIENT_ID=com.yourcompany.yourapp

# ---- Optional API flags ----
ENABLE_BILLING_API=false
ENABLE_WALLET_API=false
ENABLE_TRANSACTION_API=false
ENABLE_CONTACT_API=false
ENABLE_LABEL_API=false
