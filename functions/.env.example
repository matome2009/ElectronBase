# Firebase Functions 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp functions/.env.example functions/.env

# ---- TiDB 接続設定 ----
# TiDB Cloud Console → クラスター → 接続 から取得

TIDB_HOST_DEV=your_tidb_host.tidbcloud.com
TIDB_PORT_DEV=4000
TIDB_USER_DEV=your_tidb_user
TIDB_PASS_DEV=your_tidb_password
TIDB_DB_DEV=dev
TIDB_DB_ADMIN_DEV=dev_admin

TIDB_HOST_PRD=your_tidb_host.tidbcloud.com
TIDB_PORT_PRD=4000
TIDB_USER_PRD=your_tidb_user
TIDB_PASS_PRD=your_tidb_password
TIDB_DB_PRD=prd
TIDB_DB_ADMIN_PRD=prd_admin

# ---- SMTP メール設定 ----
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ---- Stripe 従量課金 ----
# Stripe Dashboard → API キー から取得

# DEV（テスト環境: sk_test_...）
STRIPE_SECRET_KEY_DEV=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID_DEV=price_your_dev_price_id
STRIPE_WEBHOOK_SECRET_DEV=whsec_your_dev_webhook_secret
STRIPE_METER_EVENT_NAME_DEV=your_meter_event_name

# PRD（本番環境: sk_live_...）
STRIPE_SECRET_KEY_PRD=sk_live_your_stripe_secret_key
STRIPE_PRICE_ID_PRD=price_your_prd_price_id
STRIPE_WEBHOOK_SECRET_PRD=whsec_your_prd_webhook_secret
STRIPE_METER_EVENT_NAME_PRD=your_meter_event_name
